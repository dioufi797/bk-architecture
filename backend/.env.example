PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/bk-architecture

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Cloudinary (optionnel - si tu veux utiliser Cloudinary pour les images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (pour le formulaire de contact)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_TO=contact@bk-architecture.com

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:5173

# Admin initial (pour le script seed)
ADMIN_EMAIL=admin@bk-architecture.com
ADMIN_PASSWORD=Admin@2024!
